[Unit]
Description=Dev Workspace On-Demand Session Init
ConditionPathExists=%h/bin/dws-sessions-init.sh

[Service]
Type=oneshot
ExecStart=/usr/bin/bash %h/bin/dws-sessions-init.sh
RemainAfterExit=yes
Environment=HOME=%h
Environment=PATH=/usr/local/bin:/usr/bin:/bin:%h/.local/bin
WorkingDirectory=%h

[Install]
WantedBy=default.target
